# Environment Variables
# Copy this file to .env.local and fill in your actual values

# Recruiter Flow API (placeholder)
RF_API_URL=https://api.recruiterflow.com/v1
RF_API_KEY=your_recruiter_flow_api_key_here

# hCaptcha Configuration (test keys)
HCAPTCHA_SITE_KEY=10000000-ffff-ffff-ffff-000000000001
HCAPTCHA_SECRET_KEY=0x0000000000000000000000000000000000000000

# Cloudflare Turnstile (alternative - test keys)
TURNSTILE_SITE_KEY=1x00000000000000000000000000000000000000000
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000000000000

# Next.js Configuration
NEXT_PUBLIC_APP_URL=https://www.polarispathbt.com
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Email Notifications (Resend)
RESEND_API_KEY=re_your_resend_api_key_here
NOTIFICATION_EMAIL=your_notification_email@example.com

# Rate Limiting (in-memory, configurable)
RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_WINDOW_MS=900000